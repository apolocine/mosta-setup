{
  "name": "@mostajs/setup",
  "version": "2.2.0",
  "description": "Reusable setup wizard module — multi-dialect DB configuration, .env.local writer, seed runner",
  "author": "Dr Hamid MADANI <drmdh@msn.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    },
    "./lib/cloud-mode": {
      "types": "./dist/lib/cloud-mode.d.ts",
      "import": "./dist/lib/cloud-mode.js",
      "default": "./dist/lib/cloud-mode.js"
    },
    "./lib/cloud-modules-discovery": {
      "types": "./dist/lib/cloud-modules-discovery.d.ts",
      "import": "./dist/lib/cloud-modules-discovery.js",
      "default": "./dist/lib/cloud-modules-discovery.js"
    },
    "./data/*": {
      "types": "./dist/data/*.d.ts",
      "import": "./dist/data/*.js",
      "default": "./dist/data/*.js"
    },
    "./api/*": {
      "types": "./dist/api/*.d.ts",
      "import": "./dist/api/*.js",
      "default": "./dist/api/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./components/ReconfigPanel": {
      "types": "./dist/components/ReconfigPanel.d.ts",
      "import": "./dist/components/ReconfigPanel.js",
      "default": "./dist/components/ReconfigPanel.js"
    },
    "./components/SetupWizard": {
      "types": "./dist/components/SetupWizard.d.ts",
      "import": "./dist/components/SetupWizard.js",
      "default": "./dist/components/SetupWizard.js"
    },
    "./api/routes": {
      "types": "./dist/api/routes.d.ts",
      "import": "./dist/api/routes.js",
      "default": "./dist/api/routes.js"
    },
    "./api/reconfig": {
      "types": "./dist/api/reconfig.route.d.ts",
      "import": "./dist/api/reconfig.route.js",
      "default": "./dist/api/reconfig.route.js"
    },
    "./api/upload-jar": {
      "types": "./dist/api/upload-jar.route.d.ts",
      "import": "./dist/api/upload-jar.route.js",
      "default": "./dist/api/upload-jar.route.js"
    },
    "./api/wire-module": {
      "types": "./dist/api/wire-module.route.d.ts",
      "import": "./dist/api/wire-module.route.js",
      "default": "./dist/api/wire-module.route.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "cli",
    "wire.json",
    "setup.wire.json",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "setup",
    "wizard",
    "installer",
    "database",
    "multi-dialect",
    "nextjs",
    "mosta"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/apolocine/mosta-setup"
  },
  "homepage": "https://mostajs.dev/packages/setup",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "mosta-setup": "./dist/cli/init.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test:cloud": "tsx test-scripts/test-cloud.ts"
  },
  "dependencies": {
    "@mostajs/audit": "^2.0.2",
    "@mostajs/net": "^2.0.0",
    "@mostajs/octoswitcher": "^1.0.0",
    "@mostajs/orm": "^1.7.0",
    "@mostajs/rbac": "^2.0.3",
    "@mostajs/settings": "^2.0.3",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@mostajs/menu": "^1.0.2",
    "@mostajs/socle": "^2.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@mostajs/menu": ">=1.0.2",
    "@mostajs/socle": ">=2.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@mostajs/menu": {
      "optional": true
    },
    "@mostajs/socle": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
