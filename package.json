{
  "name": "@mostajs/setup",
  "version": "1.1.0",
  "description": "Reusable setup wizard module — multi-dialect DB configuration, .env.local writer, seed runner",
  "author": "Dr Hamid MADANI <drmdh@msn.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    },
    "./data/*": {
      "types": "./dist/data/*.d.ts",
      "import": "./dist/data/*.js",
      "default": "./dist/data/*.js"
    },
    "./api/*": {
      "types": "./dist/api/*.d.ts",
      "import": "./dist/api/*.js",
      "default": "./dist/api/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "setup",
    "wizard",
    "installer",
    "database",
    "multi-dialect",
    "nextjs",
    "mosta"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/apolocine/mosta-setup"
  },
  "homepage": "https://mostajs.dev/packages/setup",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mostajs/orm": "^1.0.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^25.3.3",
    "typescript": "^5.6.0"
  }
}
