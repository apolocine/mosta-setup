{
  "name": "@mostajs/setup",
  "version": "1.4.9",
  "description": "Reusable setup wizard module — multi-dialect DB configuration, .env.local writer, seed runner",
  "author": "Dr Hamid MADANI <drmdh@msn.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    },
    "./data/*": {
      "types": "./dist/data/*.d.ts",
      "import": "./dist/data/*.js",
      "default": "./dist/data/*.js"
    },
    "./api/*": {
      "types": "./dist/api/*.d.ts",
      "import": "./dist/api/*.js",
      "default": "./dist/api/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./lib/menu": {
      "types": "./dist/lib/menu.d.ts",
      "import": "./dist/lib/menu.js",
      "default": "./dist/lib/menu.js"
    },
    "./components/ReconfigPanel": {
      "types": "./dist/components/ReconfigPanel.d.ts",
      "import": "./dist/components/ReconfigPanel.js",
      "default": "./dist/components/ReconfigPanel.js"
    },
    "./components/SetupWizard": {
      "types": "./dist/components/SetupWizard.d.ts",
      "import": "./dist/components/SetupWizard.js",
      "default": "./dist/components/SetupWizard.js"
    },
    "./api/reconfig": {
      "types": "./dist/api/reconfig.route.d.ts",
      "import": "./dist/api/reconfig.route.js",
      "default": "./dist/api/reconfig.route.js"
    },
    "./api/upload-jar": {
      "types": "./dist/api/upload-jar.route.d.ts",
      "import": "./dist/api/upload-jar.route.js",
      "default": "./dist/api/upload-jar.route.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "setup",
    "wizard",
    "installer",
    "database",
    "multi-dialect",
    "nextjs",
    "mosta"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/apolocine/mosta-setup"
  },
  "homepage": "https://mostajs.dev/packages/setup",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mostajs/orm": "^1.4.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@mostajs/menu": "^1.0.2",
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@mostajs/menu": ">=1.0.2",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@mostajs/menu": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
